# Agora Convo AI - Environment Variables for Netlify
# Copy this file to .env.local for local development
# For production, set these in your Netlify dashboard under Site settings > Environment variables

# Required: Agora Configuration
AGORA_APP_ID=your_agora_app_id_here
AGORA_CUSTOMER_ID=your_customer_id_here
AGORA_CUSTOMER_SECRET=your_customer_secret_here
AGORA_APP_CERTIFICATE=your_agora_certificate_here

# Optional: OpenAI Configuration (not needed if using LLM preset)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Microsoft TTS Configuration (not needed if using TTS preset)
# MICROSOFT_TTS_API_KEY=your_microsoft_tts_key_here
# MICROSOFT_TTS_REGION=eastus

# Optional: API URLs (defaults provided)
AGORA_API_BASE_URL=https://api.agora.io/api/conversational-ai-agent/v2
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# =============================================================================
# AGORA PRESETS (optional — if set, Agora manages the API keys)
# =============================================================================
# When a preset is set, the corresponding API key below is NOT needed.
# Leave blank to use env-var key mode instead.

# ASR preset (deepgram_nova_2, deepgram_nova_3, or leave blank for ares)
# ASR_PRESET=deepgram_nova_2
ASR_LANGUAGE=en-US

# LLM preset (openai_gpt_4o_mini, openai_gpt_4_1_mini, openai_gpt_5_nano, openai_gpt_5_mini, or leave blank for key mode)
# LLM_PRESET=openai_gpt_4o_mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_MAX_HISTORY=32

# TTS preset (minimax_speech_2_6_turbo, minimax_speech_2_8_turbo, openai_tts_1, or leave blank for Microsoft key mode)
# TTS_PRESET=minimax_speech_2_8_turbo

# MiniMax TTS preset params (used when TTS_PRESET starts with minimax_speech_)
# TTS_MINIMAX_VOICE_ID=female-shaonv
# TTS_MINIMAX_SAMPLE_RATE=32000

# OpenAI TTS preset params (used when TTS_PRESET=openai_tts_1)
# TTS_OPENAI_VOICE=alloy
# TTS_OPENAI_SPEED=1.0

# Client-side Environment Variables (for React app)
# These are used by the client and should be prefixed with REACT_APP_
REACT_APP_AGORA_APP_ID=your_agora_app_id_here
REACT_APP_AGORA_CHANNEL=onboarding_channel
REACT_APP_TTS_VENDOR=microsoft
REACT_APP_ASR_VENDOR=agora
REACT_APP_ENABLE_RTM=true
REACT_APP_ENABLE_RTC_VIDEO=true
REACT_APP_ENABLE_RTC_AUDIO=true
REACT_APP_AVATAR_ENABLED=false
REACT_APP_AGORA_FALLBACK_ENABLED=true

# Development Settings
NODE_ENV=development
PORT=3000

# Netlify Development (optional)
# NETLIFY_DEV=true 