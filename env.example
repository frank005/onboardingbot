# Agora Configuration
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
AGORA_CUSTOMER_ID=your_agora_customer_id
AGORA_CUSTOMER_SECRET=your_agora_customer_secret
AGORA_API_BASE_URL=https://api.agora.io/api/conversational-ai-agent/v2

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# Server Configuration
PORT=3001
NODE_ENV=development

# AI Bot Configuration
BOT_NAME=Welcome Bot
BOT_PERSONALITY=friendly and helpful
BOT_LANGUAGE=en
BOT_VOICE_ID=alloy

# Onboarding Configuration
ONBOARDING_FORM_FIELDS=name,birthday,bio,interests,experience_level
REQUIRED_FIELDS=name,birthday
OPTIONAL_FIELDS=bio,interests,experience_level

# Conversation Topics
ENABLE_PLATFORM_OVERVIEW=true
ENABLE_ONBOARDING_FORM=true
ENABLE_ADDITIONAL_CONVERSATION=true

# Data Collection
COLLECT_USER_PREFERENCES=true
COLLECT_SKILL_ASSESSMENT=true
COLLECT_CONVERSATION_ANALYTICS=true

# UI Configuration
ENABLE_VOICE_INPUT=true
ENABLE_TEXT_INPUT=true
ENABLE_AVATAR_DISPLAY=true
AVATAR_IMAGE_URL=https://example.com/avatar.png

# Analytics
ENABLE_CONVERSATION_LOGGING=true
ENABLE_USER_ANALYTICS=true
ENABLE_PERFORMANCE_METRICS=true

# AI Avatar Configuration
ENABLE_AI_AVATAR=false
AVATAR_VENDOR=heygen
AVATAR_API_KEY=your_avatar_api_key
AVATAR_ID=your_avatar_id
AVATAR_RTC_UID=9999

# TTS Configuration
TTS_VENDOR=microsoft
MICROSOFT_TTS_API_KEY=your_microsoft_tts_key
MICROSOFT_TTS_REGION=eastus
MICROSOFT_TTS_VOICE=en-US-JennyNeural

# ASR Configuration
ASR_VENDOR=agora
AGORA_ASR_LANGUAGE=en-US

# Advanced Features
ENABLE_AIVAD=false
ENABLE_RTM=false
ENABLE_TURN_DETECTION=true
VAD_TYPE=agora
INTERRUPT_MODE=interrupt
INTERRUPT_DURATION=160
PREFIX_PADDING=800
SILENCE_DURATION=640
VAD_THRESHOLD=0.5

# Silence Management
SILENCE_TIMEOUT=30000
SILENCE_ACTION=speak
SILENCE_MESSAGE=Are you still there? I'm here to help if you have any questions.

# MLLM Configuration (for multimodal conversations)
ENABLE_MLLM=false
MLLM_WEBSOCKET_URL=wss://api.openai.com/v1/audio/speech
MLLM_API_KEY=your_openai_api_key
MLLM_CONVERSATION_HISTORY=32
MLLM_EAGERNESS=auto

# Agora Fallback Configuration
AGORA_FALLBACK_ENABLED=true

# Real-time Communication Configuration
ENABLE_RTM_MESSAGING=true
ENABLE_RTC_VIDEO=true
ENABLE_RTC_AUDIO=true

# Advanced TTS Configuration
TTS_PROVIDER=microsoft
TTS_STREAMING=true
TTS_VOICE_SPEED=1.0
TTS_VOICE_VOLUME=1.0

# Microsoft TTS Advanced
MICROSOFT_TTS_MODEL=en-US-JennyNeural
MICROSOFT_TTS_STYLE=cheerful
MICROSOFT_TTS_RATE=1.0
MICROSOFT_TTS_VOLUME=1.0

# ElevenLabs TTS Advanced
ELEVENLABS_TTS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_TTS_VOICE_ID=your_voice_id
ELEVENLABS_TTS_MODEL=eleven_monolingual_v1
ELEVENLABS_TTS_STABILITY=0.5
ELEVENLABS_TTS_SIMILARITY_BOOST=0.75

# Cartesia TTS Advanced
CARTESIA_TTS_API_KEY=your_cartesia_api_key
CARTESIA_TTS_VOICE_ID=your_cartesia_voice_id
CARTESIA_TTS_MODEL=sonic-2

# OpenAI TTS Advanced
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_SPEED=1.0

# Hume AI TTS Advanced
HUME_TTS_API_KEY=your_hume_api_key
HUME_TTS_VOICE_ID=your_hume_voice_id
HUME_TTS_SPEED=1.0

# Advanced ASR Configuration
ASR_PROVIDER=agora
ASR_STREAMING=true
ASR_LANGUAGE=en-US
ASR_MODEL=base

# Agora ASR Advanced
AGORA_ASR_MODEL=base
AGORA_ASR_LANGUAGE=en-US
AGORA_ASR_VAD=true
AGORA_ASR_PUNCTUATION=true

# Microsoft ASR Advanced
MICROSOFT_ASR_API_KEY=your_microsoft_asr_key
MICROSOFT_ASR_REGION=eastus
MICROSOFT_ASR_LANGUAGE=en-US
MICROSOFT_ASR_MODEL=base

# Deepgram ASR Advanced
DEEPGRAM_ASR_API_KEY=your_deepgram_api_key
DEEPGRAM_ASR_MODEL=nova-2
DEEPGRAM_ASR_LANGUAGE=en-US

# AI Avatar Configuration (Optional - for visual agent representation)
AVATAR_PROVIDER=heygen
AVATAR_ENABLED=false
AVATAR_VIDEO_STREAMING=true
AVATAR_QUALITY=high
AVATAR_FPS=30

# HeyGen Avatar Advanced
HEYGEN_API_KEY=your_heygen_api_key
HEYGEN_AVATAR_ID=your_heygen_avatar_id
HEYGEN_MODEL=heygen-1.0
HEYGEN_VOICE_ID=your_heygen_voice_id

# Akool Avatar Advanced
AKOOL_API_KEY=your_akool_api_key
AKOOL_AVATAR_ID=your_akool_avatar_id
AKOOL_MODEL=akool-1.0
AKOOL_VOICE_ID=your_akool_voice_id

# Multimodal LLM Configuration
MLLM_PROVIDER=openai
MLLM_MODEL=gpt-4o
MLLM_STREAMING=true
MLLM_TURN_DETECTION=true
MLLM_VAD_TYPE=semantic
MLLM_INTERRUPT_MODE=interrupt
MLLM_SILENCE_DURATION=640
MLLM_PREFIX_PADDING=800 